# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=1 #MB
LOG_MAX_BACKUPS=7
LOG_MAX_AGE=30 #days
LOG_COMPRESS=true
LOG_CONSOLE=true

# Database Configuration
DATABASE_DRIVER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_DATABASE=athleton
DATABASE_SSL_MODE=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=72h
JWT_ISSUER=athleton

# Application Configuration
APP_NAME=athleton
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_LOG_LEVEL=info
APP_ASSETS=./assets

S3_BUCKET=kmpm-bucket
S3_REGION=us-east-1
S3_ENDPOINT=fill-if-using-custom-endpoint
S3_CDN_URL=https://athleton.sgp1.cdn.digitaloceanspaces.com
S3_ACCESS_KEY_ID=kmpm-access-key-id
S3_SECRET_ACCESS_KEY=kmpm-secret-access-key

BLEVE_INDEX_PATH=bleve
BLEVE_INDEX_TYPE=scorch

ADMIN_DEFAULT_PASSWORD=q1w2e3r4