# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_REQUEST_TIMEOUT=30s
SERVER_MAX_BODY_BYTES=10485760 # 10 MiB request body cap
# Comma-separated proxy IPs/CIDRs whose X-Forwarded-For is trusted for client IP
# (rate limiting). Empty = trust none. Set to your load balancer's CIDR in prod.
SERVER_TRUSTED_PROXIES=
# Comma-separated origins allowed for CORS (e.g. https://app.example.com).
# Empty = wildcard "*" — only safe while the API uses pure bearer tokens.
SERVER_CORS_ALLOWED_ORIGINS=

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
# Rotate the log file at this size (MB, code default 100). Every 2xx request
# logs a line at info, so a tiny value here churns backups quickly.
LOG_MAX_SIZE=10
LOG_MAX_BACKUPS=7
LOG_MAX_AGE=30 #days
LOG_COMPRESS=true
LOG_CONSOLE=true

# Database Configuration
DATABASE_DRIVER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_DATABASE=athleton
DATABASE_SSLMODE=disable

# JWT Configuration
# Generate a random secret (>=32 chars), e.g.: openssl rand -base64 48
# Placeholder values are rejected in production.
JWT_SECRET=
JWT_EXPIRATION=15m
# Refresh tokens keep their original expiry across rotation, so this is the
# absolute maximum session lifetime.
JWT_REFRESH_EXPIRATION=72h
JWT_ISSUER=athleton
# Max concurrent sessions per user; oldest is revoked beyond this. 0 = no cap.
JWT_MAX_ACTIVE_SESSIONS=10

# Application Configuration
APP_NAME=athleton
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
APP_ASSETS=./assets

S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ENDPOINT=fill-if-using-custom-endpoint
S3_CDN_URL=fill-if-serving-through-a-cdn
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
# Canned ACL for uploaded objects: public-read for CDN-served assets, private otherwise.
S3_UPLOAD_ACL=public-read

BLEVE_INDEX_PATH=bleve

# Seeded into the root/admin accounts. No default — must be set. Weak/known
# values (q1w2e3r4, password, ...) and <12 chars are rejected in production.
ADMIN_DEFAULT_PASSWORD=
# Email seeded into the root account.
ADMIN_EMAIL=root@localhost